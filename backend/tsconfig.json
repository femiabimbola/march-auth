{
  "compilerOptions": {
    "target": "ES2020",                /* Stable for Node 18/20/22+ */
    "module": "commonjs",              /* Essential for modern Node ESM */
    // "moduleResolution": "NodeNext",    /* Ensures compatibility with Node's resolution logic */
    "lib": ["ESNext"],                 /* Removed 'DOM' because this isn't a browser */
    "outDir": "./dist",
    "rootDir": "./src",
    
    /* Type Checking & Safety */
    "strict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    
    /* Backend Specifics */
    "esModuleInterop": true,           /* Crucial for importing CJS libs like Express */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,                 /* Essential for debugging in VS Code */
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}